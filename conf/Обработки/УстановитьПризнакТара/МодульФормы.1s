//*******************************************
Процедура Выполнить()
	Перем Документ, ЕстьТара, КолОбработано; // + claude

	Если (ПустоеЗначение(НачДата) = 1) Или (ПустоеЗначение(КонДата) = 1) Тогда // + claude
		Предупреждение("Вкажіть початкову та кінцеву дату періоду!");
		Возврат;
	КонецЕсли; // + claude

	КолОбработано = 0;

	Документ = СоздатьОбъект("Документ.ВозвратнаяНакладная"); // + claude
	Документ.ВыбратьДокументы(НачДата, КонДата);
	Пока Документ.ПолучитьДокумент() = 1 Цикл // + claude
		ЕстьТара = 0;
		Документ.ВыбратьСтроки();
		Пока Документ.ПолучитьСтроку() = 1 Цикл // + claude
			Если (Документ.ТМЦ.ВидТМЦ = Перечисление.ВидыТМЦ.Тара) Тогда // + claude
				ЕстьТара = 1;
			КонецЕсли; // + claude
		КонецЦикла; // + claude

		Если (ЕстьТара = 1) И (Документ.Тара <> 1) Тогда // + claude
			Документ.Тара = 1;
			Документ.Записать();
			КолОбработано = КолОбработано + 1;
		КонецЕсли; // + claude
	КонецЦикла; // + claude

	Сообщить("Встановлено ознаку Тара для " + КолОбработано + " документів Возвратна накладна.");

КонецПроцедуры
