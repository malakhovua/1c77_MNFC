// + claude
Процедура Выполнить()

	КатВременно  = Константа.КаталогВременноУдаленныхТМЦ; // + claude
	КатУдалены   = Константа.КаталогУдаленныхТМЦ; // + claude
	ДнейХранить  = Константа.ХранитьТМЦВКаталогеВременноУдаленныхДн; // + claude

	Если (ПустоеЗначение(КатВременно)) = 1 Тогда // + claude
		Предупреждение("Не задана константа КаталогВременноУдаленныхТМЦ!", 5); // + claude
		Возврат; // + claude
	КонецЕсли; // + claude
	Если (ПустоеЗначение(КатУдалены)) = 1 Тогда // + claude
		Предупреждение("Не задана константа КаталогУдаленныхТМЦ!", 5); // + claude
		Возврат; // + claude
	КонецЕсли; // + claude
	Если ДнейХранить = 0 Тогда // + claude
		Предупреждение("Не задана константа ХранитьТМЦВКаталогеВременноУдаленныхДн!", 5); // + claude
		//Возврат; // + claude
	КонецЕсли; // + claude

	ТекДата = ТекущаяДата(); // + claude

	// --- Збираємо елементи для переміщення // + claude
	СписДляПерем = СоздатьОбъект("СписокЗначений"); // + claude
	Спр = СоздатьОбъект("Справочник.ТМЦ"); // + claude
	Спр.ИспользоватьРодителя(КатВременно);  // обмежити вибірку групою
	Спр.ВыбратьЭлементы(1); // + claude
	Пока Спр.ПолучитьЭлемент() = 1 Цикл // + claude
		Если (Спр.ЭтоГруппа()) = 1 Тогда // + claude
			Продолжить; // + claude
		КонецЕсли; // + claude
		ДатаЗап = Спр.ДатаЗаписи; // + claude
		Если (ПустоеЗначение(ДатаЗап)) = 1 Тогда // + claude
			Продолжить; // + claude
		КонецЕсли; // + claude
		РазницаДней = Цел((ТекДата - ДатаЗап) / 86400); // + claude
		Если РазницаДней >= ДнейХранить Тогда // + claude
			СписДляПерем.ДобавитьЗначение(Спр.ТекущийЭлемент()); // + claude
		КонецЕсли; // + claude
	КонецЦикла; // + claude

	// --- Переміщуємо зібрані елементи // + claude
	КолПеремещено = 0; // + claude
	Спр2 = СоздатьОбъект("Справочник.ТМЦ"); // + claude
	Инд = 1; // + claude
	Пока Инд <= СписДляПерем.РазмерСписка() Цикл // + claude
		ЭлТМЦ = СписДляПерем.ПолучитьЗначение(Инд); // + claude
		Спр2.НайтиЭлемент(ЭлТМЦ); // + claude
		Спр2.Родитель = КатУдалены; // + claude
		Спр2.Записать(); // + claude
		КолПеремещено = КолПеремещено + 1; // + claude
		Инд = Инд + 1; // + claude
	КонецЦикла; // + claude

	Сообщить("Переміщено ТМЦ: " + Строка(КолПеремещено)); // + claude

КонецПроцедуры // Выполнить
