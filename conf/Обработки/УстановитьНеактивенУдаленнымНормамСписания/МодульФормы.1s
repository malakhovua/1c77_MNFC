//*******************************************
Процедура Выполнить()
	Перем Спр, ДатаНеактивен, КолОбработано, ИмяСпр, Инд;

	ДатаНеактивен = ДатаВремя(1980, 1, 1); // + claude
	КолОбработано = 0;

	МассивСправочников = СоздатьОбъект("СписокЗначений"); // + claude
	МассивСправочников.ДобавитьЗначение("УМК_НормыСписанияМатериаловУпаковокФорм");
	МассивСправочников.ДобавитьЗначение("УМК_НормыСписанияМатериаловУпаковокГрупп");
	МассивСправочников.ДобавитьЗначение("УМК_НормыСписанияМатериаловУпаковок");

	Для Инд = 1 По МассивСправочников.РазмерСписка() Цикл // + claude
		ИмяСпр = МассивСправочников.ПолучитьЗначение(Инд);
		Спр = СоздатьОбъект("Справочник." + ИмяСпр);
		КолВсего = 0;
		КолУдалено = 0;
		Спр.ВыбратьЭлементы();
		Пока Спр.ПолучитьЭлемент() = 1 Цикл
			КолВсего = КолВсего + 1;
			Если Спр.ПометкаУдаления() = 1 Тогда // + claude
				КолУдалено = КолУдалено + 1;
			КонецЕсли; // + claude
			Если (Спр.ПометкаУдаления() = 1) И (Спр.Неактивен.Получить(ДатаНеактивен) <> 1) Тогда // + claude
				Спр.Неактивен.Установить(ДатаНеактивен, 1);
				КолОбработано = КолОбработано + 1;
			КонецЕсли; // + claude
		КонецЦикла;
		Сообщить(ИмяСпр + ": всього=" + КолВсего + ", з позначкою=" + КолУдалено);
	КонецЦикла; // + claude

	Сообщить("Встановлено Неактивен для " + КолОбработано + " елементів норм списання.");
КонецПроцедуры
