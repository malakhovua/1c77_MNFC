//*******************************************
Перем ТЗДок; // + claude

Перем Расшифровка;
Перем Обновить;
Перем Таб;

Процедура Сформировать()
	
	Если Обновить = 2 Тогда
	    СтрокаДействийФормы = "#Закрыть";
	КонецЕсли;
	
	Расшифровка = СоздатьОбъект("СписокЗначений");
	
	Расшифровка.Установить("НачДата", НачДата);
	Расшифровка.Установить("КонДата", КонДата);
	Расшифровка.Установить("фПров", фПров);
	Расшифровка.Установить("фНеПров", фНеПров);
	Расшифровка.Установить("фПомУд", фПомУд);
	Расшифровка.Установить("фНеПомУд", фНеПомУд);
	Расшифровка.Установить("фСчФ", фСчФ);
	Расшифровка.Установить("ВыбМаршрут", ВыбМаршрут);
	Расшифровка.Установить("списПокупатель", списПокупатель);
	Расшифровка.Установить("Отчет", "РеестрРН");
	
	// Подготовка к заполнению выходных форм данными запроса
	Если (ТипЗначенияСтр(Таб) <> "Таблица") ИЛИ (Обновить = 0) Тогда
		Таб = СоздатьОбъект("Таблица");
	Иначе
		Таб.Очистить();
	КонецЕсли;
	
	Таб.ИсходнаяТаблица("Таблица");
	  
	СтрФ = "Включены " + ?(фСчФ = 1, "СФ", "РН") + ": ";
	СтрФ = СтрФ + ?(фПров = 1, "проведенные","");
	СтрФ = СтрФ + ?(фНеПров = 1, ?(Прав(СтрФ, 1) = "е",", ","") + "не проведенные","");
	СтрФ = СтрФ + ?(фНеПомУд= 1, ?(Прав(СтрФ, 1) = "е",", ","") + "не помеченные на удаление","");
	СтрФ = СтрФ + ?(фПомУд = 1, ?(Прав(СтрФ, 1) = "е",", ","") + "помеченные на удаление","");

	глФильтры(СтрФ, списПокупатель, "Контрагенты");
	
	//Кнопки
	Таб.ВывестиСекцию("Кнопки");
	
	Таб.ВывестиСекцию("Шапка");
	Таб.Опции(0, 0, Таб.ВысотаТаблицы(), 0);
	
	ДокРН = СоздатьОбъект("Документ." + ?(фСчФ = 1, "СчетФактура","РасходнаяНакладная"));
	ДокРН.УстановитьФильтр(фПров, фНеПров);
	ДокРН.ВыбратьДокументы(НачДата, КонДата);
	ИтСуммаСНДС = 0; ИтВес = 0; ИтПеревес = 0; ИтРазница = 0;
	НомСтр = 0; // + claude
	ТЗДок = СоздатьОбъект("ТаблицаЗначений"); // + claude
	ТЗДок.НоваяКолонка("НомСтр"); // + claude
	ТЗДок.НоваяКолонка("Документ"); // + claude

	Пока ДокРН.ПолучитьДокумент() = 1 Цикл
		Если ((фПомУд = 0) И (ДокРН.ПометкаУдаления() = 1)) ИЛИ
		     ((фНеПомУд = 0) И (ДокРН.ПометкаУдаления() = 0)) Тогда
			Продолжить;
		КонецЕсли;
		Если списПокупатель.РазмерСписка() > 0 Тогда
			Если списПокупатель.Принадлежит(ДокРН.Контрагент) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		Если ((фСчФ <> 1) И ((ПустоеЗначение(ВыбМаршрут)) = 0)) Тогда // + claude
			Если ДокРН.Маршрут <> ВыбМаршрут Тогда // + claude
				Продолжить; // + claude
			КонецЕсли; // + claude
		КонецЕсли; // + claude

		//АдресК = глАдресСтрокой(?(ПустоеЗначение(ДокРН.Договор) = 0, ДокРН.Договор.Адрес, ДокРН.Контрагент.ФизическийАдрес));
		Примечание = ДокРН.Примечание;
		СуммаСНДС = ДокРН.Итог("СуммаСНДС");
		Вес = ДокРН.ИтогоВес;
		Перевес = ДокРН.ИтогоВесК;
		Разница = Перевес - Вес;
		ИтСуммаСНДС = ИтСуммаСНДС + СуммаСНДС;
		ИтВес = ИтВес + Вес;
		ИтПеревес = ИтПеревес + Перевес;
		ИтРазница = ИтРазница + Разница;
		НомСтр = НомСтр + 1; // + claude
		ТЗДок.НоваяСтрока(); // + claude
		ТЗДок.НомСтр = НомСтр; // + claude
		ТЗДок.Документ = ДокРН.ТекущийДокумент(); // + claude
		Таб.ВывестиСекцию("Строка");
	КонецЦикла;
	
	Таб.ВывестиСекцию("Итого");
	Таб.Защита(Константа.ФлагЗащитыТаблиц);
	Таб.ТолькоПросмотр(1);
	Таб.Показать("Реестр РН");
	
КонецПроцедуры

Процедура ДобавитьВСписок(Элт, Спис)
	Если Спис.Принадлежит(Элт) = 0 Тогда
		Спис.ДобавитьЗначение(Элт, Элт.Наименование);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПодбора(Элт)
	Если Элт.Вид() = "Контрагенты" Тогда
		ДобавитьвСписок(Элт, списПокупатель);
	КонецЕсли;
КонецПроцедуры

Процедура ДобавитьЭлементВСписок(НазваниеОбъекта, Один, ИмСп = "")
	ИмСпис = ИмСп;
	КФормы = 0;
	ОткрытьПодбор(НазваниеОбъекта, "ДляВыбора", КФормы, Один);
	КФормы.ВыборГруппы(1);
КонецПроцедуры

Процедура УдалитьЗначениеСписка(Спис)
	Если Спис.ТекущаяСтрока() <> 0 Тогда
		Спис.УдалитьЗначение(Спис.ТекущаяСтрока());
	КонецЕсли;
КонецПроцедуры

Процедура ПриОткрытии()
	
	Если глФлагРасшифровки = 1 Тогда 
		
		Обновить = глОбновить;
		
		НачДата  = глРасшифровка.Получить("НачДата");
		КонДата  = глРасшифровка.Получить("КонДата");
		фПров    = глРасшифровка.Получить("фПров");
		фНеПров  = глРасшифровка.Получить("фНеПров");
		фПомУд   = глРасшифровка.Получить("фПомУд");
		фНеПомУд = глРасшифровка.Получить("фНеПомУд");
		фСчФ     = глРасшифровка.Получить("фСчФ");
		ВыбМаршрут = глРасшифровка.Получить("ВыбМаршрут");
		глРасшифровка.Получить("списПокупатель").Выгрузить(списПокупатель);
		
		Если Обновить <> 0 Тогда
			Таб = глТаблица;
		КонецЕсли;           
		
		Если Обновить <> 2 Тогда
			Сформировать();
			СтатусВозврата(0);
			Возврат;       
		КонецЕсли;           
	Иначе
		Обновить = 0;
	КонецЕсли;

	Форма.КнопкаПоУмолчанию("Сформировать");

КонецПроцедуры

Функция РасшифровкаОбновить(Обновить)
	
	Расшифровка.Установить("Обновить", Обновить);
	
	Возврат Расшифровка;
	
КонецФункции

// Обробка кліку по ячейці таблиці // + claude
Процедура ОбработкаЯчейкиТаблицы(Расшифровка, СтандОбраб, Таблица, Адрес) // + claude
	
	Перем СтрТЗ;
	
	Если Расшифровка = "СохранитиXLSX" Тогда
		глСохранитьТабДокXLSX(Таблица);
		Возврат;
	КонецЕсли;
	
	Если ((ТипЗначенияСтр(Расшифровка) = "Число") И (ПустоеЗначение(ТЗДок) = 0)) Тогда // + claude
		
		Если ТЗДок.НайтиЗначение(Расшифровка, СтрТЗ, "НомСтр") = 1 Тогда // + claude
			ТЗДок.ПолучитьСтрокуПоНомеру(СтрТЗ); // + claude
			ДокРНред = СоздатьОбъект("Документ.РасходнаяНакладная"); // + claude
			ДокРНред.НайтиДокумент(ТЗДок.Документ); // + claude
			Чис = 0;
			Если ВвестиЧисло(Чис, "Введите перевес", 15, 3) = 1 Тогда // + claude
				ДокРНред.ИтогоВесК = Чис; // + claude
				ДокРНред.Записать(); // + claude
				Обновить = 1;
				Сформировать(); // + claude
			КонецЕсли; // + claude
		КонецЕсли; // + claude
		
	Иначе
		глОбработкаЯчейкиТаблицы(Расшифровка, 1, Таблица, Адрес)	
	КонецЕсли; // + claude
	
КонецПроцедуры // ОбработкаЯчейкиТаблицы + claude

фПров = 1;
фНеПров = 1;
фПомУд = 0;
фНеПомУд = 1;