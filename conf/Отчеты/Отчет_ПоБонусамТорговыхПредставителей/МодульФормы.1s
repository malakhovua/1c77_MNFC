Перем ТабДокументы;
Перем Расшифровка;
Перем Обновить;
Перем Таб;

Процедура  Сформировать() Далее
Функция глОтфильтроватьЭлементыСотрудников(спСотрудников) Далее // + claude
Функция глПолучитьСуммуБонусов(Сотрудник, Д1, Д2) Далее // + claude
Функция глЗагрузитьОбороты(Д1, Д2, Сотрудник) Далее // + claude
Процедура глОборотыПоСхемам(ТЗОбороты, МесяцКлюч, пКво, пСумРеал, пСумДоход) Далее // + claude

///////////////////////////////////Предопределенные процедуры/////////////////////////////////////////////// 

Процедура ПриОткрытии()
	
	Если глФлагРасшифровки = 1 Тогда 
		
		Обновить = глОбновить;
		
		ДатаНачала = глРасшифровка.Получить("ДатаНачала");
		ДатаОкончания = глРасшифровка.Получить("ДатаОкончания");
		глРасшифровка.Получить("списСотрудников").Выгрузить(списСотрудников);
		
		Если Обновить <> 0 Тогда
			Таб = глТаблица;
		КонецЕсли;           
		
		Если Обновить <> 2 Тогда
			Сформировать();
			СтатусВозврата(0);
			Возврат;       
		КонецЕсли;           
	Иначе
		Обновить = 0;
	КонецЕсли;

	Форма.КнопкаПоУмолчанию("Сформировать");
	
КонецПроцедуры

///////////////////////////////////Расшифровка//////////////////////////////////////////////////////////////

Функция РасшифровкаОбновить(Обновить)
	
	Расшифровка.Установить("Обновить", Обновить);
	
	Возврат Расшифровка;
	
КонецФункции

//////////////////////////////////Команды отчета/////////////////////////////////////////////////////////////

// Список Сотрудников для отбора может содержать иерархическую группу (не только
// элементы-сотрудников). Отбрасываем группы SQL-запросом по ISFOLDER = 2
// (только элементы), список отбора грузим через УложитьСписокОбъектов -
// по образцу Отчет_ПоНачисленнойЗарплатеСотрудников // + claude
Функция глОтфильтроватьЭлементыСотрудников(спСотрудников)

	спЭлементы = СоздатьОбъект("СписокЗначений");

	Если спСотрудников.РазмерСписка() = 0 Тогда
		Возврат спЭлементы;
	КонецЕсли; // + claude

	рс = СоздатьОбъект("ODBCRecordset");
	рс.УложитьСписокОбъектов(спСотрудников, "#СпСотр", "Сотрудники");

	ТекстЗапроса =
	"SELECT Сотрудники.ID [Сотрудник $Справочник.Сотрудники]
	|FROM $Справочник.Сотрудники AS Сотрудники
	|WHERE (Сотрудники.ID IN (SELECT Val FROM #СпСотр))
	|	AND (Сотрудники.ISFOLDER = 2)";

	РезСотрудники = рс.ВыполнитьИнструкцию(ТекстЗапроса);
	РезСотрудники.Выгрузить(спЭлементы,,,"Сотрудник");

	Возврат спЭлементы;

КонецФункции // глОтфильтроватьЭлементыСотрудников // + claude

// Возвращает кредитовый оборот по счету начисления бонусов сотруднику (сч. 661)
// за период Д1-Д2, по Субконто2 = Сотрудник - прямий SQL до _1SENTRY замість
// БухгалтерскиеИтоги.ИспользоватьСубконто(...,2)/КО() (SC1 - друга позиція
// субконто, 0-індексована, відповідає позиції 2 у ИспользоватьСубконто) // + claude
Функция глПолучитьСуммуБонусов(Сотрудник, Д1, Д2)

	рс = СоздатьОбъект("ODBCRecordset");
	рс.УстановитьТекстовыйПараметр("ДатаНачала", Д1);
	рс.УстановитьТекстовыйПараметр("ДатаОкончания", Д2);
	рс.УстановитьТекстовыйПараметр("Счет", СчетПоКоду("661"));
	рс.УстановитьТекстовыйПараметр("Сотрудник", Сотрудник);

	ТекстЗапроса =
	"SELECT Sum(Проводки.SUM_) СуммаБонусов
	|FROM _1SJOURN AS Журнал
	|	INNER JOIN _1SENTRY AS Проводки ON Журнал.IDDOC = Проводки.DOCID
	|WHERE ((Журнал.CLOSED & 1) = 1)
	|	AND (Журнал.DATE_TIME_IDDOC >= :ДатаНачала)
	|	AND (Журнал.DATE_TIME_IDDOC <= :ДатаОкончания~)
	|	AND (Проводки.ACCKTID = :Счет)
	|	AND (Проводки.KTSC1 = :Сотрудник)";

	СуммаБонусов = рс.ВыполнитьСкалярный(ТекстЗапроса);

	Возврат ?(ПустоеЗначение(СуммаБонусов) = 1, 0, СуммаБонусов);

КонецФункции // глПолучитьСуммуБонусов // + claude

// SQL-запрос к Регистр.Обороты за ВЕСЬ период отчёта, отфильтрованный по конкретному
// сотруднику - джойном с табличной частью документа СхемаРасчетаБонуса по реквизиту
// Объект (тип Справочник - хранит либо Контрагента, либо Сотрудника). Подзапрос
// с DISTINCT IDDOC - чтобы несколько строк ТЧ с одним и тем же сотрудником не
// задваивали обороты по накладной. УложитьСписокОбъектов третьим параметром не
// принимает тип документа (только справочники/планы счетов) - поэтому фильтр по
// сотруднику через параметр, а не через временную таблицу. Вызывается в цикле по
// сотрудникам (см. Сформировать) - N запросов вместо N x M (сотрудник x месяц),
// как было раньше, и без самодельного индекса ИндексированнаяТаблица (LT77-296:
// поиск по нему работал некорректно) // + claude
Функция глЗагрузитьОбороты(Д1, Д2, Сотрудник)

	рс = СоздатьОбъект("ODBCRecordset");
	рс.УстановитьТекстовыйПараметр("НачалоПериода", Д1);
	рс.УстановитьТекстовыйПараметр("ОкончаниеПериода", Д2);
	рс.УстановитьТекстовыйПараметр("Сотрудник", Сотрудник);

	ТекстЗапроса =
	"SELECT Left(Журнал.DATE_TIME_IDDOC,6) МесяцКлюч
	|	, Sum(ОборотыОбороты.РасходКвоОборот) Кво
	|	, Sum(ОборотыОбороты.РасходСумОборот) СумРеал
	|	, Sum(ОборотыОбороты.ДоходОборот) СумДоход
	|FROM $Документ.РасходнаяНакладная AS РасходнаяНакладная
	|	INNER JOIN _1SJOURN AS Журнал ON РасходнаяНакладная.IDDOC = Журнал.IDDOC
	|	INNER JOIN (SELECT DISTINCT СхемаСтроки.IDDOC IDDOC
	|		FROM $ДокументСтроки.СхемаРасчетаБонуса AS СхемаСтроки
	|			INNER JOIN _1SJOURN AS СхемаЖ ON СхемаСтроки.IDDOC = СхемаЖ.IDDOC
	|		WHERE ($СхемаСтроки.Объект = :Сотрудник~)
	|			AND ((СхемаЖ.CLOSED & 1) = 1)) AS СхемыСотрудника
	|		ON $РасходнаяНакладная.СхемаРБ = СхемыСотрудника.IDDOC
	|	INNER JOIN $РегистрОбороты.Обороты(:НачалоПериода,
	|		:ОкончаниеПериода,
	|		Документ) AS ОборотыОбороты ON Журнал.DATE_TIME_IDDOC = ОборотыОбороты.ПозицияДокумента
	|WHERE (Журнал.DATE_TIME_IDDOC >= :НачалоПериода)
	|	AND (Журнал.DATE_TIME_IDDOC <= :ОкончаниеПериода~)
	|	AND ((Журнал.CLOSED & 1) = 1)
	|GROUP BY Left(Журнал.DATE_TIME_IDDOC,6)
	|UNION ALL
	|SELECT Left(Журнал.DATE_TIME_IDDOC,6) МесяцКлюч
	|	, Sum(ОборотыОбороты.РасходКвоОборот) Кво
	|	, Sum(ОборотыОбороты.РасходСумОборот) СумРеал
	|	, Sum(ОборотыОбороты.ДоходОборот) СумДоход
	|FROM $Документ.ВозвратнаяНакладная AS ВозвратнаяНакладная
	|	INNER JOIN _1SJOURN AS Журнал ON ВозвратнаяНакладная.IDDOC = Журнал.IDDOC
	|	INNER JOIN (SELECT DISTINCT СхемаСтроки.IDDOC IDDOC
	|		FROM $ДокументСтроки.СхемаРасчетаБонуса AS СхемаСтроки
	|			INNER JOIN _1SJOURN AS СхемаЖ ON СхемаСтроки.IDDOC = СхемаЖ.IDDOC
	|		WHERE ($СхемаСтроки.Объект = :Сотрудник~)
	|			AND ((СхемаЖ.CLOSED & 1) = 1)) AS СхемыСотрудника
	|		ON $ВозвратнаяНакладная.СхемаРБ = СхемыСотрудника.IDDOC
	|	INNER JOIN $РегистрОбороты.Обороты(:НачалоПериода,
	|		:ОкончаниеПериода,
	|		Документ) AS ОборотыОбороты ON Журнал.DATE_TIME_IDDOC = ОборотыОбороты.ПозицияДокумента
	|WHERE (Журнал.DATE_TIME_IDDOC >= :НачалоПериода)
	|	AND (Журнал.DATE_TIME_IDDOC <= :ОкончаниеПериода~)
	|	AND ((Журнал.CLOSED & 1) = 1)
	|GROUP BY Left(Журнал.DATE_TIME_IDDOC,6)";

	РезОбороты = рс.ВыполнитьИнструкцию(ТекстЗапроса);

	ТЗОбороты = СоздатьОбъект("ТаблицаЗначений");
	ТЗОбороты.Загрузить(РезОбороты);
	
	Возврат ТЗОбороты;

КонецФункции // глЗагрузитьОбороты // + claude

// Суммирует Кво/СуммаРеализовано/СуммаДоход из ТЗОбороты (см. глЗагрузитьОбороты,
// уже отфильтрованной по сотруднику) за месяц МесяцКлюч (ГГГГММ). Таблица маленькая
// (пара строк на месяц из UNION ALL), поэтому простой перебор строк, без индекса // + claude
Процедура глОборотыПоСхемам(ТЗОбороты, МесяцКлюч, пКво, пСумРеал, пСумДоход)

	пКво = 0;
	пСумРеал = 0;
	пСумДоход = 0;

	ТЗОбороты.ВыбратьСтроки();
	Пока ТЗОбороты.ПолучитьСтроку() = 1 Цикл
		Если ТЗОбороты.МесяцКлюч = МесяцКлюч Тогда
			пКво = пКво + ТЗОбороты.Кво;
			пСумРеал = пСумРеал + ТЗОбороты.СумРеал;
			пСумДоход = пСумДоход + ТЗОбороты.СумДоход;
		КонецЕсли; // + claude
	КонецЦикла; // + claude

КонецПроцедуры // глОборотыПоСхемам // + claude

Процедура Сформировать()

	Если ПустоеЗначение(ДатаНачала) = 1 Тогда
		Предупреждение("Не заполнена дата начала периода");
		Возврат;
	КонецЕсли; // + claude

	Если ПустоеЗначение(ДатаОкончания) = 1 Тогда
		Предупреждение("Не заполнена дата окончания периода");
		Возврат;
	КонецЕсли; // + claude

	Если списСотрудников.РазмерСписка() = 0 Тогда
		Предупреждение("Не выбраны торговые представители");
		Возврат;
	КонецЕсли; // + claude
	
	
	Если Обновить = 2 Тогда
		СтрокаДействийФормы = "#Закрыть";
	КонецЕсли;
	
	//Расшифровка
	Расшифровка = СоздатьОбъект("СписокЗначений");
	
	Расшифровка.Установить("ДатаНачала", ДатаНачала);
	Расшифровка.Установить("ДатаОкончания", ДатаОкончания);
	
	Расшифровка.Установить("списТМЦ", списСотрудников);
		
	Расшифровка.Установить("Отчет", "Отчет_ПоБонусамТорговыхПредставителей");
	Расшифровка.Установить("Обновить");
	
	// Подготовка к заполнению выходных форм данными запроса
	Если (ТипЗначенияСтр(Таб) <> "Таблица") ИЛИ (Обновить=0) Тогда
		Таб = СоздатьОбъект("Таблица");
	Иначе
		Таб.Очистить();
	КонецЕсли;

	// список отбора может содержать иерархическую группу - берём только элементы // + claude
	списЭлементовСотрудников = глОтфильтроватьЭлементыСотрудников(списСотрудников);

	Если списЭлементовСотрудников.РазмерСписка() = 0 Тогда
		Предупреждение("Среди выбранных торговых представителей нет элементов (только группы)");
		Возврат;
	КонецЕсли; // + claude

	Состояние("Формирование отчета...");

	// таблица месяцев периода - в ней же копим итоги по столбцам (по месяцу, по всем сотрудникам) // + claude
	ТЗМесяцы = СоздатьОбъект("ТаблицаЗначений");
	ТЗМесяцы.НоваяКолонка("НачМ");
	ТЗМесяцы.НоваяКолонка("КонМ");
	ТЗМесяцы.НоваяКолонка("Месяц");
	ТЗМесяцы.НоваяКолонка("МесяцКлюч");
	ТЗМесяцы.НоваяКолонка("Кво");
	ТЗМесяцы.НоваяКолонка("СумРеал");
	ТЗМесяцы.НоваяКолонка("СумДоход");
	ТЗМесяцы.НоваяКолонка("СумБонус"); // + claude

	ТекМесяц = НачМесяца(ДатаНачала);
	Пока ТекМесяц <= ДатаОкончания Цикл
		ТЗМесяцы.НоваяСтрока();
		ТЗМесяцы.НачМ = Макс(ДатаНачала, ТекМесяц);
		ТЗМесяцы.КонМ = Мин(ДатаОкончания, КонМесяца(ТекМесяц));
		ТЗМесяцы.Месяц = Формат(ТекМесяц, "ДММММГГГГ");
		ТЗМесяцы.МесяцКлюч = Лев(Формат(ТекМесяц, "ДГГГГММДД"), 6);;
		ТЗМесяцы.Кво = 0;
		ТЗМесяцы.СумРеал = 0;
		ТЗМесяцы.СумДоход = 0;
		ТЗМесяцы.СумБонус = 0;
		ТекМесяц = ДобавитьМесяц(ТекМесяц, 1);
	КонецЦикла; // + claude

	Таб.ИсходнаяТаблица("ТаблицаОтчета");
	//Кнопки
	Таб.ВывестиСекцию("Кнопки");
	
	// Шапка: колонка "Сотрудник" (заголовок "Торговый представник") открывает
	// строку, затем по одному блоку "Период" на месяц и блок "ПириодИтоги" // + claude
	Таб.ВывестиСекцию("Шапка|Сотрудник");
	
	Таб.Опции(0, 0, Таб.ВысотаТаблицы(), 0);
	
	Состояние("Заполнение выходной таблицы...");
	
	ТЗМесяцы.ВыбратьСтроки();
	Пока ТЗМесяцы.ПолучитьСтроку() = 1 Цикл
		ПериодМесяц = ТЗМесяцы.Месяц;
		Таб.ПрисоединитьСекцию("Шапка|Период");
	КонецЦикла;
	Таб.ПрисоединитьСекцию("Шапка|ПириодИтоги"); // + claude

	ГрандКво = 0;
	ГрандСуммаРеализовано = 0;
	ГрандСуммаДоход = 0;
	ГрандСуммаБонусы = 0; // + claude

	Для НС = 1 По списЭлементовСотрудников.РазмерСписка() Цикл

		Сотрудник = списЭлементовСотрудников.ПолучитьЗначение(НС);

		// запрос по оборотам фильтруется по сотруднику (джойн с ТЧ СхемаРасчетаБонуса) - в цикле по сотрудникам // + claude
		ТЗОбороты = глЗагрузитьОбороты(ДатаНачала, ДатаОкончания, Сотрудник);

		ИтогоКвоЕмп = 0;
		ИтогоСуммаРеализованоЕмп = 0;
		ИтогоСуммаДоходЕмп = 0;
		ИтогоСуммаБонусыЕмп = 0; // + claude

		СотрудникНаименование = СокрЛП(Сотрудник.Наименование);

		Таб.ВывестиСекцию("Строка|Сотрудник");

		Кво = 0;
		СуммаРеализовано = 0;
		СуммаДоход = 0; // + claude (объявление до передачи как выходных параметров)

		ТЗМесяцы.ВыбратьСтроки();
		Пока ТЗМесяцы.ПолучитьСтроку() = 1 Цикл

			глОборотыПоСхемам(ТЗОбороты, ТЗМесяцы.МесяцКлюч, Кво, СуммаРеализовано, СуммаДоход);

			СуммаБонусы = глПолучитьСуммуБонусов(Сотрудник, ТЗМесяцы.НачМ, ТЗМесяцы.КонМ);

			СуммаБонусыНаКг = ?(Кво <> 0, Окр(СуммаБонусы / Кво, 2), 0);
			ПроцентБонусовКРеализации = ?(СуммаРеализовано <> 0, Окр(СуммаБонусы / СуммаРеализовано * 100, 2), 0); // + claude

			ИтогоКвоЕмп = ИтогоКвоЕмп + Кво;
			ИтогоСуммаРеализованоЕмп = ИтогоСуммаРеализованоЕмп + СуммаРеализовано;
			ИтогоСуммаДоходЕмп = ИтогоСуммаДоходЕмп + СуммаДоход;
			ИтогоСуммаБонусыЕмп = ИтогоСуммаБонусыЕмп + СуммаБонусы; // + claude

			// накопление итогов по столбцу (месяцу) для секции "Итоги" // + claude
			ТЗМесяцы.Кво = ТЗМесяцы.Кво + Кво;
			ТЗМесяцы.СумРеал = ТЗМесяцы.СумРеал + СуммаРеализовано;
			ТЗМесяцы.СумДоход = ТЗМесяцы.СумДоход + СуммаДоход;
			ТЗМесяцы.СумБонус = ТЗМесяцы.СумБонус + СуммаБонусы; // + claude

			Таб.ПрисоединитьСекцию("Строка|Период");

		КонецЦикла; // + claude

		ИтогоПериодСтрокаКво = ИтогоКвоЕмп;
		ИтогоПериодСтрокаСуммаРеализовано = ИтогоСуммаРеализованоЕмп;
		ИтогоПериодСтрокаСуммаДоход = ИтогоСуммаДоходЕмп;
		ИтогоПериодСтрокаСуммаБонусы = ИтогоСуммаБонусыЕмп;
		ИтогоПериодСтрокаСуммаБонусыНаКг = ?(ИтогоКвоЕмп <> 0, Окр(ИтогоСуммаБонусыЕмп / ИтогоКвоЕмп, 2), 0);
		ИтогоПериодСтрокаПроцентБонусовКРеализации = ?(ИтогоСуммаРеализованоЕмп <> 0, Окр(ИтогоСуммаБонусыЕмп / ИтогоСуммаРеализованоЕмп * 100, 2), 0); // + claude

		Таб.ПрисоединитьСекцию("Строка|ПириодИтоги");

		ГрандКво = ГрандКво + ИтогоКвоЕмп;
		ГрандСуммаРеализовано = ГрандСуммаРеализовано + ИтогоСуммаРеализованоЕмп;
		ГрандСуммаДоход = ГрандСуммаДоход + ИтогоСуммаДоходЕмп;
		ГрандСуммаБонусы = ГрандСуммаБонусы + ИтогоСуммаБонусыЕмп; // + claude

	КонецЦикла; // + claude

	// Итоги: "Разом:" + один блок "Период" на месяц (итог по столбцу) + блок "Итого" (общий итог) // + claude
	Таб.ВывестиСекцию("Итоги|Сотрудник");

	ТЗМесяцы.ВыбратьСтроки();
	Пока ТЗМесяцы.ПолучитьСтроку() = 1 Цикл

		ИтогоКво = ТЗМесяцы.Кво;
		ИтогоКвоСуммаРеализовано = ТЗМесяцы.СумРеал;
		ИтогоКвоСуммаДоход = ТЗМесяцы.СумДоход;
		ИтогоКвоСуммаБонусы = ТЗМесяцы.СумБонус;
		ИтогоКвоСуммаБонусыНаКг = ?(ТЗМесяцы.Кво <> 0, Окр(ТЗМесяцы.СумБонус / ТЗМесяцы.Кво, 2), 0);
		ИтогоКвоПроцентБонусовКРеализации = ?(ТЗМесяцы.СумРеал <> 0, Окр(ТЗМесяцы.СумБонус / ТЗМесяцы.СумРеал * 100, 2), 0); // + claude

		Таб.ПрисоединитьСекцию("Итоги|Период");

	КонецЦикла; // + claude

	ИтогоПериодКвоКво = ГрандКво;
	ИтогоПериодСуммаРеализовано = ГрандСуммаРеализовано;
	ИтогоПериодСуммаДоход = ГрандСуммаДоход;
	ИтогоПериодСуммаБонусы = ГрандСуммаБонусы;
	ИтогоПериодСуммаБонусыНаКг = ?(ГрандКво <> 0, Окр(ГрандСуммаБонусы / ГрандКво, 2), 0);
	ИтогоПериодПроцентБонусовКРеализации = ?(ГрандСуммаРеализовано <> 0, Окр(ГрандСуммаБонусы / ГрандСуммаРеализовано * 100, 2), 0); // + claude

	Таб.ПрисоединитьСекцию("Итоги|ПириодИтоги");

	Таб.ТолькоПросмотр(1);
	Таб.Показать("Отчет по бонусам торговых представителей", "");

КонецПроцедуры

///////////////////////////////////Работа со списками отбора и подбором///////////////////////////////////////

Процедура ДобавитьВСписок(Элт, Спис)
	
	Если Спис.Принадлежит(Элт) = 0 Тогда
		Спис.ДобавитьЗначение(Элт, Элт.Наименование);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПодбора(Элт)
	
	Если Элт.Вид() = "Сотрудники" Тогда
		ДобавитьвСписок(Элт, списСотрудников);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьЭлементВСписок(НазваниеОбъекта, Один, ИмСп = "")
	
	ИмСпис = ИмСп;
	КФормы = 0;
	ОткрытьПодбор(НазваниеОбъекта, "ДляВыбора", КФормы, Один);
	КФормы.ВыборГруппы(1);
	
КонецПроцедуры

Процедура УдалитьЗначениеСписка(Спис)
	
	Если Спис.ТекущаяСтрока() <> 0 Тогда
		Спис.УдалитьЗначение(Спис.ТекущаяСтрока());
	КонецЕсли;
	
КонецПроцедуры


